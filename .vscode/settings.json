
{
  "cSpell.words": [
    "abdelrhanm",
    "Heroicon",
    "jobseeker"
  ],
  "todo-tree.regex.regex": "\\b(TODO|FIX|NOTE|SECTION)\\b",
  "todo-tree.regex.regexCaseSensitive": true,
  "todo-tree.highlights.highlightDelay": 0,
  "todo-tree.highlights.customHighlight": {
    "TODO": {
      "foreground": "#7AAACE",
      "fontStyle": "bold"
    },
    "FIX": {
      "foreground": "#ff0000",
      "fontStyle": "bold"
    },
    "NOTE": {
      "foreground": "#00ff00",
      "fontStyle": "bold"
    },
    "SECTION": {
      "foreground": "#ffcc00",
      "fontStyle": "bold"
    }
  },
  "todo-tree.general.tags": [
    "TODO",
    "FIX",
    "NOTE",
    "SECTION"
  ]
}
